@model IEnumerable<inventario_herramientas.Managers.Entidades.Herramientas>
@using Microsoft.AspNetCore.Mvc.Localization
@using Microsoft.Extensions.Localization
@using inventario_herramientas.Web.Helpers
@inject IStringLocalizer<SharedResource> Localizer

@{
    ViewData["Title"] = Localizer["ListTitle"];

    var categorias = new Dictionary<int, string> {
        { 1, Localizer["Category_Electric"] },
        { 2, Localizer["Category_Manual"] },
        { 3, Localizer["Category_PPE"] }
    };

    var ubicaciones = new Dictionary<int, string> {
        { 1, Localizer["Location_CompA"] },
        { 2, Localizer["Location_WarehouseB"] },
        { 3, Localizer["Location_RepairShop"] },
        { 4, Localizer["Location_Worksite"] }
    };

    var estados = new Dictionary<int, string> {
        { 1, Localizer["Status_Available"] },
        { 2, Localizer["Status_InUse"] },
        { 3, Localizer["Status_Damaged"] },
        { 4, Localizer["Status_InRepair"] }
    };
}

@section Styles {
    <link href="~/css/index.css" rel="stylesheet" asp-append-version="true" />
}

<!-- Header de página -->
<div class="page-header">
    <div class="page-header-info">
        <h1 class="page-title">@Localizer["PageTitle"]</h1>
        <p class="page-subtitle">@Localizer["PageSubtitle"]</p>
    </div>
    <div class="page-header-actions" style="display: flex; gap: 10px;">

        <!-- Botón para ver Looker Studio -->
        <a href="@Localizer["Link_DashboardBI"]" target="_blank" class="btn-dashboard" title="@Localizer["Title_DashboardBI"]">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect><line x1="3" y1="9" x2="21" y2="9"></line><line x1="9" y1="21" x2="9" y2="9"></line></svg>
            @Localizer["DashboardBI"]
        </a>

        <!-- Botón para descargar el CSV de la base de datos -->
        <a asp-controller="Herramientas" asp-action="ExportarCSV" class="btn-success-custom">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path><polyline points="7 10 12 15 17 10"></polyline><line x1="12" y1="15" x2="12" y2="3"></line></svg>
            @Localizer["ExportCSV"]
        </a>

        @if (User.HasClaim("admin", "Administradora"))
        {
            <a asp-controller="Herramientas" asp-action="Create" class="btn-primary-custom">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="12" y1="5" x2="12" y2="19" /><line x1="5" y1="12" x2="19" y2="12" /></svg>
                @Localizer["NewTool"]
            </a>
        }
    </div>
</div>

<!-- DASHBOARD (Métricas rápidas) -->
<div class="dashboard-cards">
    <!-- Tarjeta 1: Total -->
    <div class="stat-card">
        <div class="stat-icon stat-blue">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"></path>
                <polyline points="3.27 6.96 12 12.01 20.73 6.96"></polyline>
                <line x1="12" y1="22.08" x2="12" y2="12"></line>
            </svg>
        </div>
        <div class="stat-info">
            <span class="stat-label">@Localizer["TotalModels"]</span>
            <span class="stat-value">@Model.Count()</span>
        </div>
    </div>

    <!-- Tarjeta 2: En Reparación -->
    <div class="stat-card">
        <div class="stat-icon stat-orange">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="12" r="3"></circle>
                <path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1 0 2.83 2 2 0 0 1-2.83 0l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-2 2 2 2 0 0 1-2-2v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83 0 2 2 0 0 1 0-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1-2-2 2 2 0 0 1 2-2h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 0-2.83 2 2 0 0 1 2.83 0l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 2-2 2 2 0 0 1 2 2v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 0 2 2 0 0 1 0 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 2 2 2 2 0 0 1-2 2h-.09a1.65 1.65 0 0 0-1.51 1z"></path>
            </svg>
        </div>
        <div class="stat-info">
            <span class="stat-label">@Localizer["Status_InRepair"]</span>
            <span class="stat-value">@Model.Count(x => x.estado_id == 4)</span>
        </div>
    </div>

    <!-- Tarjeta 3: Stock Crítico -->
    <div class="stat-card">
        <div class="stat-icon stat-red">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"></path>
                <line x1="12" y1="9" x2="12" y2="13"></line>
                <line x1="12" y1="17" x2="12.01" y2="17"></line>
            </svg>
        </div>
        <div class="stat-info">
            <span class="stat-label">@Localizer["CriticalStock"]</span>
            <span class="stat-value">@Model.Count(x => x.cantidad < 5)</span>
        </div>
    </div>
</div>

<!-- BARRA DE BÚSQUEDA -->
<div class="search-wrapper">
    <div class="search-input-container">
        <svg class="search-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="11" cy="11" r="8"></circle>
            <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
        </svg>
        <input type="text" id="searchInput" class="form-control-custom input-with-icon" placeholder="@Localizer["SearchPlaceholder"]" />
    </div>
</div>

<!-- Tabla -->
<div class="table-wrapper">
    <div class="table-responsive-scroll">
        <table class="data-table">
            <thead>
                <tr>
                    <th>@Localizer["Header_Name"]</th>
                    <th>@Localizer["Header_Description"]</th>
                    <th>@Localizer["Header_Stock"]</th>
                    <th>@Localizer["Header_Category"]</th>
                    <th>@Localizer["Header_Location"]</th>
                    <th>@Localizer["Header_Status"]</th>
                    <th>@Localizer["Header_Modification"]</th>
                    <th class="th-actions">@Localizer["Header_Actions"]</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>
                            <span class="cell-bold">@Localizer[item.nombre ?? ""]</span>
                        </td>
                        <td class="cell-muted" title="@Localizer[item.descripcion ?? ""]">@Localizer[item.descripcion ?? ""]</td>
                        <td>
                            <span class="badge-qty">@item.cantidad</span>
                        </td>
                        <td>
                            <span class="text-category">@(categorias.ContainsKey(item.categoria_id) ? categorias[item.categoria_id] : Localizer["Category_Other"])</span>
                        </td>
                        <td class="cell-location">
                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="icon-location">
                                <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path>
                                <circle cx="12" cy="10" r="3"></circle>
                            </svg>
                            @(ubicaciones.ContainsKey(item.ubicacion_id) ? ubicaciones[item.ubicacion_id] : Localizer["Location_Unknown"])
                        </td>
                        <td>
                            @{
                                var estadoNombre = estados.ContainsKey(item.estado_id) ? estados[item.estado_id] : Localizer["Status_Unknown"];
                                var claseColor = item.estado_id switch
                                {
                                    1 => "status-success",
                                    2 => "status-info",
                                    3 => "status-danger",
                                    4 => "status-warning",
                                    _ => "status-default"
                                };
                            }
                            <span class="badge-status @claseColor">
                                <span class="status-dot"></span>
                                @estadoNombre
                            </span>
                        </td>
                        <td class="cell-date">@String.Format("{0:dd/MM/yy}", item.fecha_modificacion)</td>

                        <td>
                            <div class="action-group">
                                <a href="javascript:void(0)"
                                   onclick="mostrarModalAuditoria('@item.NombreUsuarioAlta', '@(item.fechaAlta?.ToString("yyyy-MM-ddTHH:mm:ss"))', '@item.NombreUsuarioModificacion', '@(item.fechaModificacion?.ToString("yyyy-MM-ddTHH:mm:ss"))')"
                                   class="btn-action btn-audit"
                                   title="@Localizer["Title_Audit"]">
                                    <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                        <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"></path>
                                        <circle cx="12" cy="12" r="3"></circle>
                                    </svg>
                                </a>

                                <a asp-action="Edit" asp-controller="Herramientas" asp-route-id="@item.id_herramienta" class="btn-action btn-edit" title="@Localizer["Title_Edit"]">
                                    <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                        <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7" />
                                        <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z" />
                                    </svg>
                                </a>
                                <a href="javascript:void(0)" onclick="mostrarModalDemo()" class="btn-action btn-delete" title="@Localizer["Title_Delete"]">
                                    <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                        <polyline points="3 6 5 6 21 6" />
                                        <path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2" />
                                        <line x1="10" y1="11" x2="10" y2="17" />
                                        <line x1="14" y1="11" x2="14" y2="17" />
                                    </svg>
                                </a>
                            </div>
                        </td>

                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<!-- Modal de Auditoría -->
<div id="modalAuditoria" class="demo-overlay">
    <div class="demo-modal" style="text-align: left; max-width: 500px;">
        <div style="display: flex; align-items: center; gap: 12px; margin-bottom: 24px; padding-bottom: 16px; border-bottom: 1px solid var(--border-subtle);">
            <div class="stat-icon stat-blue" style="width: 40px; height: 40px;">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 20h9"></path><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"></path></svg>
            </div>
            <h3 class="demo-title" style="margin: 0;">@Localizer["Audit_Title"]</h3>
        </div>

        <div style="margin-bottom: 20px;">
            <p style="font-size: 12px; color: var(--text-muted); margin-bottom: 4px; text-transform: uppercase; font-weight: 600;">@Localizer["Audit_CreatedBy"]</p>
            <p style="font-size: 15px; color: var(--text-primary); margin: 0; display: flex; justify-content: space-between;">
                <span id="auditCreador" style="font-weight: 500;"></span>
                <span id="auditFechaCreacion" style="color: var(--text-secondary);"></span>
            </p>
        </div>

        <div>
            <p style="font-size: 12px; color: var(--text-muted); margin-bottom: 4px; text-transform: uppercase; font-weight: 600;">@Localizer["Audit_LastModifiedBy"]</p>
            <p style="font-size: 15px; color: var(--text-primary); margin: 0; display: flex; justify-content: space-between;">
                <span id="auditModificador" style="font-weight: 500;"></span>
                <span id="auditFechaModificacion" style="color: var(--text-secondary);"></span>
            </p>
        </div>

        <button onclick="cerrarModalAuditoria()" class="btn-secondary-custom" style="width: 100%; justify-content: center; margin-top: 32px;">@Localizer["Audit_Close"]</button>
    </div>
</div>

<!-- Modal de Modo Demo -->
<div id="modalDemo" class="demo-overlay">
    <div class="demo-modal">
        <div class="demo-icon-wrapper">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect>
                <path d="M7 11V7a5 5 0 0 1 10 0v4"></path>
            </svg>
        </div>
        <h3 class="demo-title">@Localizer["Demo_Blocked"]</h3>
        <p class="demo-text">@Html.Raw(Localizer["Demo_Text"])</p>
        <button onclick="cerrarModalDemo()" class="btn-primary-custom btn-demo-close">@Localizer["Demo_Accept"]</button>
    </div>
</div>

@section Scripts {
    <script>
        function mostrarModalDemo() {
            document.getElementById('modalDemo').classList.add('show');
        }

        function cerrarModalDemo() {
            document.getElementById('modalDemo').classList.remove('show');
        }

        $(document).ready(function(){
            $("#searchInput").on("keyup", function() {
                var value = $(this).val().toLowerCase();

                $(".data-table tbody tr").filter(function() {
                    $(this).toggle($(this).text().toLowerCase().indexOf(value) > -1)
                });
            });
        });

        function mostrarModalAuditoria(creador, fechaCreacion, modificador, fechaMod) {
            const fCreacion = (fechaCreacion && fechaCreacion !== "") ? new Date(fechaCreacion).toLocaleString() : "@Localizer["JS_NoDate"]";
            const fMod = (fechaMod && fechaMod !== "") ? new Date(fechaMod).toLocaleString() : "@Localizer["JS_NoModifications"]";

            document.getElementById('auditCreador').innerText = creador || '@Localizer["JS_System"]';
            document.getElementById('auditFechaCreacion').innerText = fCreacion;

            document.getElementById('auditModificador').innerText = modificador || '@Localizer["JS_NA"]';
            document.getElementById('auditFechaModificacion').innerText = fMod;

            document.getElementById('modalAuditoria').classList.add('show');
        }

        function cerrarModalAuditoria() {
            document.getElementById('modalAuditoria').classList.remove('show');
        }
    </script>
}