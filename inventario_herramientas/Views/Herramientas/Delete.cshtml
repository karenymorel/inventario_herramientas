@model inventario_herramientas.Managers.Entidades.Herramientas

@{
    ViewData["Title"] = "Eliminar Herramienta";
}

<h2>Eliminar Herramienta</h2>

<h3>¿Estás seguro de que quieres eliminar esta herramienta?</h3>
<div>
    <dl class="row">
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.nombre)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.nombre)
        </dd>
    </dl>

    <form asp-action="DeleteConfirmed" asp-route-id="@Model.id_herramienta" method="post">
        <input type="hidden" asp-for="id_herramienta" />
        @Html.AntiForgeryToken()
        <input type="submit" value="Eliminar" class="btn btn-danger" /> |
        <a asp-controller="Home" asp-action="Index" class="btn btn-secondary">Volver a la lista</a>
    </form>
</div>