@using System.IO
@using Microsoft.AspNetCore.Mvc.Localization
@using Microsoft.Extensions.Localization
@using inventario_herramientas.Web.Helpers
@inject IStringLocalizer<SharedResource> Localizer

@{
    var paginaActual = ViewContext.RouteData.Values["action"].ToString();
}
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - @Localizer["BrandTitle"]</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/login.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/index.css" asp-append-version="true" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
    @RenderSection("Styles", false)
</head>
<body>

    @if (paginaActual != "LoginIndex" && paginaActual != "LogOut")
    {
        <div class="app-layout">

            <!-- Sidebar -->
            <aside class="sidebar">
                <!-- Logo / Brand -->
                <div class="sidebar-brand">
                    <div class="brand-icon">
                        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z" />
                        </svg>
                    </div>
                    <span class="brand-text">@Localizer["Sidebar_Brand"]</span>
                </div>

                <div class="sidebar-divider"></div>

                <!-- Saludo -->
                @if (Context.User.Identity.IsAuthenticated)
                {
                    <div class="sidebar-user">
                        <div class="user-avatar">
                            @User.Identity.Name.Substring(0, 1).ToUpper()
                        </div>
                        <div class="user-info">
                            <span class="user-greeting">@Localizer["Sidebar_Greeting"]</span>
                            <span class="user-name">@User.Identity.Name</span>
                        </div>
                    </div>
                }

                <div class="sidebar-divider"></div>

                <!-- Navegación -->
                <nav class="sidebar-nav">
                    <ul class="nav-list">
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Home" asp-action="Index">
                                <span class="nav-icon">
                                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                        <rect x="3" y="3" width="7" height="7" rx="1" />
                                        <rect x="14" y="3" width="7" height="7" rx="1" />
                                        <rect x="3" y="14" width="7" height="7" rx="1" />
                                        <rect x="14" y="14" width="7" height="7" rx="1" />
                                    </svg>
                                </span>
                                <span class="nav-text">@Localizer["Sidebar_List"]</span>
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Herramientas" asp-action="Create">
                                <span class="nav-icon">
                                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                        <circle cx="12" cy="12" r="10" />
                                        <line x1="12" y1="8" x2="12" y2="16" />
                                        <line x1="8" y1="12" x2="16" y2="12" />
                                    </svg>
                                </span>
                                <span class="nav-text">@Localizer["Sidebar_Create"]</span>
                            </a>
                        </li>
                    </ul>
                </nav>

                <!-- Bottom nav -->
                <div class="sidebar-bottom">
                    <div class="sidebar-divider"></div>

                    @if (Context.User.Identity.IsAuthenticated)
                    {
                        <!-- Mostrar "Cerrar Sesión" si el usuario está logueado -->
                        <div style="padding: 0.5rem 1rem;">
                            <a asp-controller="Login" asp-action="LogOut"
                               style="color: #ff6b6b; display: flex; align-items: center; gap: 10px; text-decoration: none; font-size: 0.9rem; padding: 0.5rem; border-radius: 6px; transition: background 0.2s;"
                               onmouseover="this.style.background='rgba(255,107,107,0.1)'"
                               onmouseout="this.style.background='transparent'">
                                <span style="display: flex; align-items: center; color: #ff6b6b;">
                                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                        <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"></path>
                                        <polyline points="16 17 21 12 16 7"></polyline>
                                        <line x1="21" y1="12" x2="9" y2="12"></line>
                                    </svg>
                                </span>
                                <span>@Localizer["Sidebar_Logout"]</span>
                            </a>
                        </div>
                    }
                    else
                    {
                        <!-- Mostrar "Iniciar Sesión" si entró como Invitado -->
                        <div style="padding: 0.5rem 1rem;">
                            <a asp-controller="Login" asp-action="LoginIndex"
                               style="color: #4ade80; display: flex; align-items: center; gap: 10px; text-decoration: none; font-size: 0.9rem; padding: 0.5rem; border-radius: 6px; transition: background 0.2s;"
                               onmouseover="this.style.background='rgba(74,222,128,0.1)'"
                               onmouseout="this.style.background='transparent'">
                                <span style="display: flex; align-items: center; color: #4ade80;">
                                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                        <path d="M15 3h4a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2h-4"></path>
                                        <polyline points="10 17 15 12 10 7"></polyline>
                                        <line x1="15" y1="12" x2="3" y2="12"></line>
                                    </svg>
                                </span>
                                <span>@Localizer["LoginTitle"]</span>
                            </a>
                        </div>
                    }

                    <div class="sidebar-divider" style="margin-top: 0.5rem;"></div>

                    <div class="sidebar-language-selector"
                         style="padding: 0 1rem 1rem 1rem; text-align: center;">
                        <form asp-controller="Culture"
                              asp-action="SetCulture" method="post"
                              id="langForm">
                            <input type="hidden"
                                   name="returnUrl"
                                   value="@Context.Request.Path@Context.Request.QueryString" />
                            <select name="culture"
                                    onchange="this.form.submit()"
                                    class="form-select form-select-sm"
                                    style="background: #2c2c2c; color: white; border: 1px solid #444; cursor: pointer;">
                                <option value="es-AR"
                                        selected="@(System.Threading.Thread.CurrentThread.CurrentUICulture.Name == "es-AR")">🇪🇸 Español</option>
                                <option value="en-US"
                                        selected="@(System.Threading.Thread.CurrentThread.CurrentUICulture.Name == "en-US")">🇺🇸 English</option>
                            </select>
                        </form>
                    </div>
                </div>
            </aside>

            <!-- Contenido principal -->
            <main class="main-content">
                @RenderBody()
            </main>
        </div>
    }
    else
    {
        <div class="container cont_principal">
            <main role="main" class="pb-3">
                @RenderBody()
            </main>
        </div>
    }

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>